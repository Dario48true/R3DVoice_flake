generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())

  totpSecret    String?
  totpEnabledAt DateTime?

  // Base64-encoded X25519 public key for E2EE DMs. Generated client-side at
  // register; the matching private key never reaches the server. Optional
  // because legacy accounts created before E2EE shipped won't have one.
  e2eePublicKey String?

  handle   String?  @unique
  dndUntil DateTime?

  sessions      Session[]
  ownedRooms    Room[]           @relation("RoomOwner")
  memberships   RoomMembership[]
  messages      Message[]
  friendshipsRequested  Friendship[] @relation("FriendshipRequester")
  friendshipsReceived   Friendship[] @relation("FriendshipRecipient")
  invites       Invite[]
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Room {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  // When true, anyone with the room ID/link can join — token mint skips the
  // membership check. When false (default for new rooms), only the owner +
  // explicitly-invited members get a LiveKit token. Existing rooms get
  // isPublic=true via migration backfill to preserve historical behavior.
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  owner       User             @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships RoomMembership[]
  invites     Invite[]

  @@index([ownerId])
}

model RoomMembership {
  userId     String
  roomId     String
  lastJoined DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
  @@index([roomId])
}

// Polymorphic chat message — backs both per-room chat and 1:1 DMs.
//
// threadType is "room" or "dm".
//   room: threadId = roomId (FK semantics enforced in handler, not at DB level
//         since the Room → Message relation is loose: Messages outlive Rooms
//         being deleted only by cascade through application logic, not Prisma).
//   dm:   threadId = canonical pair "<smaller-uuid>:<larger-uuid>" so both
//         participants resolve the same thread.
model Message {
  id         String   @id @default(uuid())
  threadType String   // "room" | "dm"
  threadId   String
  authorId   String
  body       String
  createdAt  DateTime @default(now())
  editedAt   DateTime?
  deletedAt  DateTime?

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadType, threadId, createdAt])
  @@index([authorId])
}

// Friendship between two users. Stored directionally — `requesterId` sent the
// request, `recipientId` received it. status transitions:
//   pending  → accepted (recipient accepts)
//   pending  → rejected (recipient rejects; row is deleted by handler)
//   accepted → blocked  (either side blocks)
// Uniqueness enforced at the canonical-pair level via the @@unique constraint.
model Friendship {
  id           String   @id @default(uuid())
  requesterId  String
  recipientId  String
  status       String   // "pending" | "accepted" | "blocked"
  requestedAt  DateTime @default(now())
  respondedAt  DateTime?

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("FriendshipRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status])
  @@index([requesterId, status])
}

model Invite {
  id           String    @id @default(uuid())
  code         String    @unique
  kind         String    // 'room' | 'friend' — enforced in app layer (zod)
  creatorId    String
  creator      User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  targetRoomId String?
  targetRoom   Room?     @relation(fields: [targetRoomId], references: [id], onDelete: Cascade)
  expiresAt    DateTime?
  maxUses      Int?
  uses         Int       @default(0)
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([code])
  @@index([creatorId])
}
