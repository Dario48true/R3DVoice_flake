{
  "name": "@redvoice/client",
  "version": "0.1.1",
  "private": true,
  "description": "RedVoice – low-latency voice/video communication for gamers",
  "author": {
    "name": "R3dWolfie",
    "email": "arui939@gmail.com"
  },
  "homepage": "https://github.com/R3dWolfie/RedVoice",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "package": "electron-builder",
